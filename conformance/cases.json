{
  "comment": "Shared ELQ builder conformance table. Each case id is bound to a builder expression in typescript/test/conformance.test.ts and python/tests/test_conformance.py; both suites must cover every id and produce the exact `elq` string, so the two SDKs provably emit identical queries. Expected strings follow the canonical style of the ELLIO Search API query printer and are verified as fixed points of the server grammar before every release.",
  "cases": [
    { "id": "term_keyword", "elq": "classification:\"malicious\"" },
    { "id": "term_bool", "elq": "spoofable:false" },
    { "id": "term_int", "elq": "network.port:23" },
    { "id": "term_ip_bare", "elq": "ip:198.51.100.7" },
    { "id": "term_cidr_bare", "elq": "ip:203.0.113.0/24" },
    { "id": "term_wildcard", "elq": "rdns:\"*.googleusercontent.com\"" },
    { "id": "term_slash", "elq": "http.path:\"/wp-login.php\"" },
    { "id": "term_space", "elq": "tag:\"Telnet Bruteforce\"" },
    { "id": "term_parens", "elq": "http.user_agent:\"Mozilla/5.0 (compatible; zgrab/0.x)\"" },
    { "id": "term_embedded_dquote", "elq": "ssh.auth.password:'pa\"ss'" },
    { "id": "term_colons", "elq": "fingerprints.muonfp:\"64240:2-4-8-1-3:1460:7\"" },
    { "id": "not_term", "elq": "tag!:\"ssh_bruteforce\"" },
    { "id": "match", "elq": "http.path~:\"admin\"" },
    { "id": "not_match", "elq": "http.user_agent!~:\"curl\"" },
    { "id": "eq_int", "elq": "src.asn.number = 13335" },
    { "id": "eq_ip", "elq": "ip = 198.51.100.7" },
    { "id": "ne_bool", "elq": "spoofable != true" },
    { "id": "gt", "elq": "src.geo.latitude > 50" },
    { "id": "gte", "elq": "src.asn.number >= 1000" },
    { "id": "lt", "elq": "active_days < 30" },
    { "id": "lte", "elq": "active_days <= 5" },
    { "id": "in_ints", "elq": "network.port IN (22, 23, 2323)" },
    { "id": "in_strings", "elq": "src.geo.country.code IN (\"CN\", \"RU\", \"KP\")" },
    { "id": "range_dates", "elq": "first_seen:[2026-06-01 TO 2026-06-30]" },
    { "id": "range_ints", "elq": "network.port:[8000 TO 9000]" },
    { "id": "exists", "elq": "classification exists" },
    { "id": "not_exists", "elq": "rdns not_exists" },
    { "id": "within", "elq": "last_seen:7d" },
    { "id": "within_leading_zero", "elq": "last_seen:7d" },
    { "id": "date_cmp", "elq": "last_seen >= 2026-07-01" },
    { "id": "and_flat", "elq": "classification:\"malicious\" AND network.port:23" },
    { "id": "or_flat", "elq": "src.geo.country.code:\"CN\" OR src.geo.country.code:\"RU\"" },
    { "id": "or_of_and_no_parens", "elq": "tag:\"mirai\" AND spoofable:false OR classification:\"benign\"" },
    { "id": "and_of_or_parens", "elq": "(src.geo.country.code:\"CN\" OR src.geo.country.code:\"RU\") AND classification:\"malicious\"" },
    { "id": "not_clause", "elq": "NOT spoofable:true" },
    { "id": "not_group", "elq": "NOT (tag:\"mirai\" OR tag:\"gafgyt\")" },
    { "id": "raw_composed", "elq": "(tag:\"mirai\" OR tag:\"gafgyt\") AND seen:true" },
    { "id": "mixed_nested", "elq": "(src.geo.country.code:\"CN\" OR src.geo.country.code:\"RU\") AND NOT spoofable:true AND network.port IN (22, 23)" }
  ]
}
